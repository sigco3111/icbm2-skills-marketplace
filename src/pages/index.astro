---
import Layout from '../layouts/Layout.astro';
import SkillCard from '../components/SkillCard.astro';
import CategoryFilter from '../components/CategoryFilter.astro';
import skillsData from '../data/skills.json';

const { categories, skills } = skillsData;

const baseUrl = '/icbm2-skills-marketplace';

// Load download manifest
import downloadsData from '../data/downloads.json';
const downloadableSlugs: Set<string> = new Set(Object.keys(downloadsData));

const hasDownload = (slug: string) => downloadableSlugs.has(slug);

// Use Korean description by default, English description for toggle
const getDesc = (skill: any) => skill.description_ko || skill.description;
const getDescEn = (skill: any) => skill.description_en || skill.description || '';

// Featured skills (first 6 by default order)
const featuredSkills = skills.slice(0, 6);

// Recent skills (last 6 by default order = newest by file mtime)
const recentSkills = [...skills].sort((a, b) => (b.created_at || 0) - (a.created_at || 0)).slice(0, 6);

// Category icon mapping
const categoryIcons: Record<string, string> = {
  'code-quality': '🔧',
  'documentation': '📝',
  'testing': '🧪',
  'database': '🗄️',
  'api': '🌐',
  'devops': '🚀',
  'security': '🔒',
  'frontend': '🎨',
  'backend': '⚙️',
  'data-processing': '📊',
  'git': '📦',
  'monitoring': '📡',
  'performance': '⚡',
  'configuration': '⚙️',
  'analysis': '🔍',
  'refactoring': '♻️',
  'validation': '✅',
  'utilities': '🛠️',
  'communication': '💬',
  'design': '🎨',
  'learning': '📚',
  'automation': '🤖',
};
---

<Layout title="ICBM2 Skills Marketplace — AI 에이전트 스킬 마켓플레이스">
  <!-- Hero Section -->
  <section class="relative overflow-hidden hero-pattern">
    <div class="absolute inset-0 bg-gradient-to-b from-accent/5 via-transparent to-transparent"></div>
    <div class="absolute top-20 left-1/4 w-72 h-72 bg-accent/10 rounded-full blur-3xl"></div>
    <div class="absolute top-40 right-1/4 w-96 h-96 bg-purple-500/5 rounded-full blur-3xl"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-16 text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-accent/20 bg-accent/5 text-accent text-sm font-medium mb-8">
        <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
        {skills.length} Skills Available
      </div>

      <!-- Title -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight mb-6">
        <span class="text-dark-text">ICBM2</span>
        <br class="sm:hidden" />
        <span class="gradient-text"> Skills Marketplace</span>
      </h1>

      <p class="text-lg sm:text-xl text-dark-muted max-w-2xl mx-auto mb-10 leading-relaxed">
        AI 에이전트를 위한 스킬 라이브러리입니다.<br class="hidden sm:block" />
        Explore <span class="text-accent font-semibold">{skills.length}</span> skills across <span class="text-accent font-semibold">{categories.length}</span> categories to supercharge your AI agent.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="#skills"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-accent text-dark-bg font-semibold hover:bg-accent-hover transition-all duration-200 shadow-lg shadow-accent/25 hover:shadow-accent/40"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
          Browse All Skills
        </a>
        <a
          href="#categories"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-dark-border text-dark-muted font-medium hover:text-dark-text hover:border-dark-muted hover:bg-dark-surface/30 transition-all duration-200"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
          </svg>
          View Categories
        </a>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-3 gap-8 max-w-lg mx-auto mt-16">
        <div>
          <div class="text-3xl sm:text-4xl font-bold text-dark-text">{skills.length}</div>
          <div class="text-sm text-dark-muted mt-1">Skills</div>
        </div>
        <div>
          <div class="text-3xl sm:text-4xl font-bold text-dark-text">{categories.length}</div>
          <div class="text-sm text-dark-muted mt-1">Categories</div>
        </div>
        <div>
          <div class="text-3xl sm:text-4xl font-bold text-dark-text">{Math.round(skills.reduce((sum, s) => sum + (s.reading_time_minutes || 0), 0))}m</div>
          <div class="text-sm text-dark-muted mt-1">Content</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories Section -->
  <section id="categories" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h2 class="text-2xl font-bold text-dark-text">Categories</h2>
        <p class="text-dark-muted text-sm mt-1">카테고리별로 스킬을 탐색하세요</p>
      </div>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3">
      {categories.map(cat => (
        <a
          href={`${baseUrl}/category/${cat.slug}`}
          class="group flex flex-col items-center gap-2 p-4 rounded-xl border border-dark-border/40 bg-dark-surface/20 hover:bg-dark-surface/50 hover:border-accent/30 transition-all duration-300 text-center"
        >
          <span class="text-2xl">{categoryIcons[cat.slug] || '📋'}</span>
          <span class="text-sm font-medium text-dark-text group-hover:text-accent transition-colors">{cat.name}</span>
          <span class="text-xs text-dark-muted">{cat.count} skills</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Featured Skills -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h2 class="text-2xl font-bold text-dark-text">Featured Skills</h2>
        <p class="text-dark-muted text-sm mt-1">추천 스킬 — 핵심 카테고리의 필수 스킬</p>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {featuredSkills.map(skill => (
        <SkillCard
          name={skill.name}
          slug={skill.slug}
          category={skill.category}
          categorySlug={categories.find(c => c.name === skill.category)?.slug || ''}
          description={getDesc(skill)}
          descriptionEn={getDescEn(skill)}
          version={skill.version}
          tags={skill.tags}
          author={skill.author}
          hasDownload={hasDownload(skill.slug)}
        />
      ))}
    </div>
  </section>

  <!-- Recent Skills -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h2 class="text-2xl font-bold text-dark-text">Recent Skills</h2>
        <p class="text-dark-muted text-sm mt-1">최근 추가된 스킬</p>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {recentSkills.map(skill => (
        <SkillCard
          name={skill.name}
          slug={skill.slug}
          category={skill.category}
          categorySlug={categories.find(c => c.name === skill.category)?.slug || ''}
          description={getDesc(skill)}
          descriptionEn={getDescEn(skill)}
          version={skill.version}
          tags={skill.tags}
          author={skill.author}
          hasDownload={hasDownload(skill.slug)}
        />
      ))}
    </div>
  </section>

  <!-- All Skills -->
  <section id="skills" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h2 class="text-2xl font-bold text-dark-text">All Skills</h2>
        <p class="text-dark-muted text-sm mt-1">전체 스킬 목록 ({skills.length}개)</p>
      </div>
    </div>

    <!-- Category filter -->
    <div class="mb-6">
      <CategoryFilter categories={categories} />
    </div>

    <!-- Sort controls -->
    <div class="flex items-center gap-2 mb-6">
      <span class="text-sm text-dark-muted mr-1">정렬:</span>
      <button
        data-sort="default"
        class="sort-btn active-sort inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium border transition-all duration-200 cursor-pointer bg-accent text-dark-bg border-accent"
      >
        기본
      </button>
      <button
        data-sort="name-asc"
        class="sort-btn inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium border transition-all duration-200 cursor-pointer bg-dark-surface/30 text-dark-muted border-dark-border/50 hover:text-dark-text hover:border-dark-border"
      >
        이름 A→Z
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
      <button
        data-sort="name-desc"
        class="sort-btn inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium border transition-all duration-200 cursor-pointer bg-dark-surface/30 text-dark-muted border-dark-border/50 hover:text-dark-text hover:border-dark-border"
      >
        이름 Z→A
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
        </svg>
      </button>
      <button
        data-sort="newest"
        class="sort-btn inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium border transition-all duration-200 cursor-pointer bg-dark-surface/30 text-dark-muted border-dark-border/50 hover:text-dark-text hover:border-dark-border"
      >
        최신순
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </button>
      <button
        data-sort="oldest"
        class="sort-btn inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium border transition-all duration-200 cursor-pointer bg-dark-surface/30 text-dark-muted border-dark-border/50 hover:text-dark-text hover:border-dark-border"
      >
        오래된순
        <svg class="w-3 h-3 rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </button>
    </div>

    <!-- Skills grid -->
    <div id="skills-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
      {skills.map((skill, index) => (
        <div
          class="skill-card-wrapper"
          data-name={skill.name.toLowerCase()}
          data-created-at={skill.created_at || 0}
          data-default-index={index}
        >
          <SkillCard
            name={skill.name}
            slug={skill.slug}
            category={skill.category}
            categorySlug={categories.find(c => c.name === skill.category)?.slug || ''}
            description={getDesc(skill)}
            descriptionEn={getDescEn(skill)}
            version={skill.version}
            tags={skill.tags}
            author={skill.author}
            compact={true}
            hasDownload={hasDownload(skill.slug)}
          />
        </div>
      ))}
    </div>
  </section>
</Layout>

<script>
  // Sort functionality for All Skills grid
  const grid = document.getElementById('skills-grid');
  const sortBtns = document.querySelectorAll('.sort-btn');

  function sortGrid(method: string) {
    if (!grid) return;
    const cards = Array.from(grid.querySelectorAll('.skill-card-wrapper')) as HTMLElement[];

    cards.sort((a, b) => {
      switch (method) {
        case 'name-asc':
          return (a.dataset.name || '').localeCompare(b.dataset.name || '');
        case 'name-desc':
          return (b.dataset.name || '').localeCompare(a.dataset.name || '');
        case 'newest':
          return parseInt(b.dataset.created_at || '0') - parseInt(a.dataset.created_at || '0');
        case 'oldest':
          return parseInt(a.dataset.created_at || '0') - parseInt(b.dataset.created_at || '0');
        default:
          return parseInt(a.dataset.defaultIndex || '0') - parseInt(b.dataset.defaultIndex || '0');
      }
    });

    // Re-append in sorted order with animation
    cards.forEach((card, i) => {
      card.style.opacity = '0';
      card.style.transform = 'translateY(8px)';
      grid.appendChild(card);
      requestAnimationFrame(() => {
        setTimeout(() => {
          card.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
          card.style.opacity = '1';
          card.style.transform = 'translateY(0)';
        }, i * 20);
      });
    });
  }

  sortBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const method = btn.getAttribute('data-sort');
      if (!method) return;

      // Update active state
      sortBtns.forEach(b => {
        b.classList.remove('active-sort', 'bg-accent', 'text-dark-bg', 'border-accent');
        b.classList.add('bg-dark-surface/30', 'text-dark-muted', 'border-dark-border/50');
      });
      btn.classList.add('active-sort', 'bg-accent', 'text-dark-bg', 'border-accent');
      btn.classList.remove('bg-dark-surface/30', 'text-dark-muted', 'border-dark-border/50');

      sortGrid(method);
    });
  });
</script>
