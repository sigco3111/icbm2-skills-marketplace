---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Page Not Found" description="The page you're looking for doesn't exist.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 text-center">
    <!-- Animated 404 -->
    <div class="relative inline-block mb-8">
      <div class="text-8xl sm:text-9xl font-extrabold gradient-text">404</div>
      <div class="absolute -inset-4 bg-accent/5 rounded-full blur-2xl -z-10"></div>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-dark-text mb-4">
      Page Not Found
    </h1>

    <p class="text-dark-muted text-lg max-w-md mx-auto mb-10">
      요청하신 페이지를 찾을 수 없습니다.<br />
      The page you're looking for doesn't exist.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="/icbm2-skills-marketplace/"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-accent text-dark-bg font-semibold hover:bg-accent-hover transition-all duration-200 shadow-lg shadow-accent/25"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
        Go Home
      </a>
      <a
        href="/icbm2-skills-marketplace/#categories"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-dark-border text-dark-muted font-medium hover:text-dark-text hover:border-dark-muted hover:bg-dark-surface/30 transition-all duration-200"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
        </svg>
        Browse Categories
      </a>
    </div>
  </div>
</Layout>
