---
import Layout from '../../layouts/Layout.astro';
import SkillCard from '../../components/SkillCard.astro';
import skillsData from '../../data/skills.json';
import { readFileSync } from 'node:fs';

let downloadableSlugs: Set<string> = new Set();
try {
  const dl = JSON.parse(readFileSync('./public/downloads/downloads.json', 'utf-8'));
  downloadableSlugs = new Set(Object.keys(dl));
} catch {}

export function getStaticPaths() {
  const { categories, skills } = skillsData;
  return categories.map(cat => ({
    params: { slug: cat.slug },
    props: { category: cat, skills }
  }));
}

const { slug } = Astro.params;
const { category, skills } = Astro.props;

const categorySkills = skills.filter(s => {
  const catSlug = skillsData.categories.find(c => c.name === s.category)?.slug;
  return catSlug === slug;
});

const baseUrl = '/icbm2-skills-marketplace';
---

<Layout title={`${category.name} — ICBM2 Skills Marketplace`} description={`${category.name} 카테고리의 ${categorySkills.length}개 스킬을 탐색하세요.`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-dark-muted mb-8">
      <a href={`${baseUrl}/`} class="hover:text-accent transition-colors">Home</a>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
      <span class="text-dark-text">{category.name}</span>
    </nav>

    <!-- Header -->
    <div class="mb-10">
      <h1 class="text-3xl sm:text-4xl font-bold text-dark-text mb-3">{category.name}</h1>
      <p class="text-dark-muted text-lg">
        {categorySkills.length}개의 스킬이 있습니다
      </p>
    </div>

    <!-- Skills Grid -->
    {categorySkills.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        {categorySkills.map(skill => (
          <SkillCard
            name={skill.name}
            slug={skill.slug}
            category={skill.category}
            categorySlug={slug}
            description={skill.description_ko || skill.description}
            version={skill.version}
            tags={skill.tags}
            author={skill.author}
            hasDownload={downloadableSlugs.has(skill.slug)}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-20">
        <svg class="w-16 h-16 mx-auto text-dark-muted/30 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
        </svg>
        <p class="text-dark-muted">이 카테고리에 스킬이 없습니다</p>
      </div>
    )}

    <!-- Back to all categories -->
    <div class="mt-12 pt-8 border-t border-dark-border/30">
      <a href={`${baseUrl}/#categories`} class="inline-flex items-center gap-2 text-dark-muted hover:text-accent transition-colors text-sm">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Back to all categories
      </a>
    </div>
  </div>
</Layout>
